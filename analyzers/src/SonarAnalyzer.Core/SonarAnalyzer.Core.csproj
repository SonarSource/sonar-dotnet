<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <!-- Do not use a version of Google.Protobuf that depends on System.Memory due to performance problems: https://github.com/dotnet/roslyn/issues/58863 -->
    <PackageReference Include="Google.Protobuf" Version="3.6.1" />
    <!-- Grpc.Tools 2.26.0 contains tools/windows_x64/protoc.exe 3.8 which is the latest version compatible with Google.Protobuf 3.6.1 -->
    <PackageReference Include="Grpc.Tools" Version="2.26.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.Composition" Version="1.0.27">
      <!-- This package is a dependency of Microsoft.CodeAnalysis.CSharp.Workspaces. It is safe to use since it's compatible with .Net Portable runtime -->
      <NoWarn>NU1701</NoWarn>
    </PackageReference>
    <PackageReference Include="Microsoft.CodeAnalysis.Workspaces.Common" Version="1.3.2" />
    <PackageReference Include="System.Collections.Immutable" Version="1.1.37">
      <!-- Downgrade System.Collections.Immutable to support VS2015 Update 3 -->
      <NoWarn>NU1605, NU1701</NoWarn>
    </PackageReference>
    <PackageReference Include="SonarAnalyzer.CommonsConfigurations" Version="2.29.0.5138" GeneratePathProperty="true" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <!-- We need to update NuGet and JAR packaging after changing references -->
    <ProjectReference Include="..\SonarAnalyzer.CFG\SonarAnalyzer.CFG.csproj" />
    <!-- Runs SecretExclusionPatternsGenerator over the shared secret-patterns.json fed as an AdditionalFile below. -->
    <ProjectReference Include="..\SonarAnalyzer.SourceGenerators\SonarAnalyzer.SourceGenerators.csproj" SetTargetFramework="TargetFramework=netstandard2.0" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Feeds the shared content/secret-patterns.json from SonarAnalyzer.CommonsConfigurations to SecretExclusionPatternsGenerator. The JSON is surfaced as an AdditionalFile the generator picks up via the SecretPatternsFile metadata.
      To refresh the shared regexes, bump the SonarAnalyzer.CommonsConfigurations package version.
    -->
    <AdditionalFiles Include="$(PKGSonarAnalyzer_CommonsConfigurations)\content\secret-patterns.json" SecretPatternsFile="true" />
    <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="SecretPatternsFile" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Microsoft.CodeAnalysis" />
    <Using Include="Microsoft.CodeAnalysis.Diagnostics" />
    <Using Include="SonarAnalyzer.Core.AnalysisContext" />
    <Using Include="SonarAnalyzer.Core.Analyzers" />
    <Using Include="SonarAnalyzer.Core.Common" />
    <Using Include="SonarAnalyzer.Core.Extensions" />
    <Using Include="SonarAnalyzer.Core.Facade" />
    <Using Include="SonarAnalyzer.Core.Semantics" />
    <Using Include="SonarAnalyzer.Core.Semantics.Extensions" />
    <Using Include="SonarAnalyzer.Core.Syntax.Extensions" />
    <Using Include="SonarAnalyzer.Core.Syntax.Utilities" />
    <Using Include="SonarAnalyzer.ShimLayer" />
    <Using Include="StyleCop.Analyzers.Lightup" />
  </ItemGroup>

  <ItemGroup>
    <Protobuf Include="Protobuf/AnalyzerReport.proto" />
  </ItemGroup>

</Project>

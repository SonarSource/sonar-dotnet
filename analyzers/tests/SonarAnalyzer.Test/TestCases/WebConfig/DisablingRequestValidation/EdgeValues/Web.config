<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.web>
    <compilation debug="true" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" />
    <pages validateRequest="FALSE" /> <!-- Noncompliant {{Ensure ASP.NET Request Validation is not disabled.}} -->
    <httpRuntime requestValidationMode="1.2" /> <!--Noncompliant-->
  </system.web>
</configuration>
